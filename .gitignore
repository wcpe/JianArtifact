# IDE / 操作系统
/.idea/
.vscode/
.DS_Store
Thumbs.db

# Rust 构建产物（Cargo.lock 为二进制项目保留入库）
/target/
**/*.rs.bk

# 前端构建产物与依赖
node_modules/
dist/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 运行期数据与产物（含隐私/密钥，严禁入库）
/data/
*.db
*.db-shm
*.db-wal
*.log
/logs/

# 本地配置（仅提交 config.example.toml 占位，真实配置不入库）
config.toml
config.local.toml

# 环境与密钥（不入库）
.env
.env.local

# 过程性文档与临时文件（不入库）
/.tmp/
